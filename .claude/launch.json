    {
      "name": "API (Next.js)",
      "runtimeExecutable": "/bin/bash",
      "runtimeArgs": ["-c", "export PATH=/usr/local/bin:/opt/homebrew/bin:$PATH && pnpm --filter @kalitedb/api dev"],
