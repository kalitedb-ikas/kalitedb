rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function currentRole() {
      return isAuthed() ? request.auth.token.role : null;
    }

    function hasRole(role) {
      return currentRole() == role;
    }

    function canReadReports() {
      return hasRole('admin') || hasRole('team') || hasRole('ceo') || hasRole('qt');
    }

    function canManageReports() {
      return hasRole('admin') || hasRole('team');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isOwnQtEntry(userKey) {
      return isAuthed() && hasRole('qt') && request.auth.uid == userKey;
    }

    match /reportPeriods/{periodId} {
      allow get, list: if canReadReports();
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/agentMetrics/{recordId} {
      allow get, list: if canReadReports();
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/auditMetrics/{recordId} {
      allow get, list: if canReadReports();
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/questionPerformance/{recordId} {
      allow get, list: if canReadReports();
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/qtMetrics/{recordId} {
      allow get, list: if canReadReports();
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/qtManualEntries/{userKey} {
      allow get, list: if canReadReports();
      allow create, update: if canManageReports() || isOwnQtEntry(userKey);
      allow delete: if isAdmin();
    }

    match /thresholdConfigs/{metricId} {
      allow get, list: if canReadReports();
      allow create, update, delete: if isAdmin();
    }

    match /userRoles/{emailKey} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /importJobs/{jobId} {
      allow get, list: if canManageReports();
      allow create, update, delete: if canManageReports();
    }
  }
}
