rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function currentRole() {
      return !isAuthed()
        ? null
        : request.auth.token.role != null
          ? request.auth.token.role
          : request.auth.token.email != null &&
            exists(/databases/$(database)/documents/userRoles/$(request.auth.token.email))
            ? get(/databases/$(database)/documents/userRoles/$(request.auth.token.email)).data.role
            : null;
    }

    function hasRole(role) {
      return currentRole() == role;
    }

    function canReadReports() {
      return hasRole('admin') || hasRole('team') || hasRole('ceo') || hasRole('qt');
    }

    function isPublishedPeriodData(periodData) {
      return periodData.status == 'published' || periodData.publishedAt != null;
    }

    function isPublishedPeriodResource() {
      return resource != null && isPublishedPeriodData(resource.data);
    }

    function isPublishedPeriod(periodId) {
      return exists(/databases/$(database)/documents/reportPeriods/$(periodId)) &&
        isPublishedPeriodData(get(/databases/$(database)/documents/reportPeriods/$(periodId)).data);
    }

    function canManageReports() {
      return hasRole('admin') || hasRole('team');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isOwnQtEntry(userKey) {
      return isAuthed() && hasRole('qt') && request.auth.uid == userKey;
    }

    match /reportPeriods/{periodId} {
      allow get, list: if canReadReports() || isPublishedPeriodResource();
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/agentMetrics/{recordId} {
      allow get, list: if canReadReports() || isPublishedPeriod(periodId);
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/auditMetrics/{recordId} {
      allow get, list: if canReadReports() || isPublishedPeriod(periodId);
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/questionPerformance/{recordId} {
      allow get, list: if canReadReports() || isPublishedPeriod(periodId);
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/qtMetrics/{recordId} {
      allow get, list: if canReadReports() || isPublishedPeriod(periodId);
      allow create, update, delete: if canManageReports();
    }

    match /reportPeriods/{periodId}/qtManualEntries/{userKey} {
      allow get, list: if canReadReports() || isPublishedPeriod(periodId);
      allow create, update: if canManageReports() || isOwnQtEntry(userKey);
      allow delete: if isAdmin();
    }

    match /thresholdConfigs/{metricId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /userRoles/{emailKey} {
      allow get: if isAdmin() || (isAuthed() && request.auth.token.email == emailKey);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /importJobs/{jobId} {
      allow get, list: if canManageReports();
      allow create, update, delete: if canManageReports();
    }
  }
}
