rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Kimlik doğrulama ────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.role == 'admin';
    }

    // ─── Koleksiyon kuralları ────────────────────────────────────────────────
    // Tüm rollere admin yetkisi verildi — giriş yapan herkes okuyabilir/yazabilir.
    // Yalnızca userRoles ve users koleksiyonları admin ile sınırlandırıldı
    // (privilege escalation engeli).

    // Dönem üst dokümanı
    match /reportPeriods/{periodId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Agent metrikleri
    match /reportPeriods/{periodId}/agentMetrics/{recordId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Audit metrikleri
    match /reportPeriods/{periodId}/auditMetrics/{recordId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Soru performansı
    match /reportPeriods/{periodId}/questionPerformance/{recordId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // QT metrikleri
    match /reportPeriods/{periodId}/qtMetrics/{recordId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Role-play metrikleri (satış)
    match /reportPeriods/{periodId}/roleplayMetrics/{recordId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Değerlendirme soruları (satış)
    match /reportPeriods/{periodId}/evaluationQuestions/{questionId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // QT manuel girişleri
    match /reportPeriods/{periodId}/qtManualEntries/{userKey} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Eşik konfigürasyonları
    match /thresholdConfigs/{metricId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Eski kullanıcı rolleri — sadece admin yazabilir (privilege escalation engeli)
    match /userRoles/{emailKey} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAdmin();
    }

    // Yeni kullanıcı dokümanları — sadece admin yazabilir
    match /users/{emailKey} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAdmin();
    }

    // Takımlar
    match /teams/{teamId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Satış KPI verileri
    match /reportPeriods/{periodId}/salesKpiData/{docId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Satış toplantıları
    match /reportPeriods/{periodId}/salesMeetings/{meetingId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Temsilci yönetimi
    match /representatives/{repKey} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Eğitim takvimi etkinlikleri
    match /trainingEvents/{eventId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // RAMP endeksi girişleri ve hedefleri
    match /reportPeriods/{periodId}/rampEntries/{docId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Başarı endeksi manuel girişleri
    match /reportPeriods/{periodId}/successIndexEntries/{agentKey} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // İçe aktarma işleri
    match /importJobs/{jobId} {
      allow get, list: if isAuthed();
      allow create, update, delete: if isAuthed();
    }

    // Audit logları — herkes yazabilir (loglama), sadece admin silebilir
    match /auditLogs/{logId} {
      allow get, list: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if isAdmin();
    }
  }
}
